<UserControl
    x:Class="CBHK.CustomControl.TagRichTextBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:TextElement="clr-namespace:CBHK.CustomControl.TextElement"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CBHK.CustomControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Input:VectorTextBox
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            Background="#323334"
            BorderBrush="#424242"
            BorderThickness="1"
            CaretBrush="White"
            FontSize="15"
            Foreground="White"
            KeyDown="TextBox_KeyDown"
            Style="{DynamicResource VectorTextBoxStyle}"
            WaterMarkerBrush="Gray"
            WaterMarkerMargin="5 0 0 0"
            WaterMarkerText="输入后按下回车创建标签" />
        <RichTextBox
            x:Name="tagBox"
            Grid.Row="1"
            Background="#565A57"
            BorderThickness="0"
            CaretBrush="White"
            Foreground="White"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            VerticalScrollBarVisibility="Auto">
            <TextElement:EnabledFlowDocument>
                <Paragraph />
            </TextElement:EnabledFlowDocument>
        </RichTextBox>
    </Grid>
</UserControl>

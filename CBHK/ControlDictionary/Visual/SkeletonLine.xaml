<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Storyboard x:Key="SkeletonLineAnimation">
        <DoubleAnimation
            AutoReverse="True"
            RepeatBehavior="Forever"
            Storyboard.TargetProperty="Fill.GradientStops[1].Offset"
            To="1"
            Duration="0:0:1" />
    </Storyboard>

    <Style x:Key="SkeletonLineStyle" TargetType="Rectangle">
        <Setter Property="Margin" Value="-10,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Fill">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Offset="0" Color="#7F4A4A4A" />
                    <GradientStop Offset="0" Color="#7F313131" />
                    <GradientStop Offset="1" Color="#7F4A4A4A" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource SkeletonLineAnimation}" />
            </EventTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
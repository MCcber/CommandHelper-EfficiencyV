<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Storyboard x:Key="SkeletonBlockAnimation">
        <ColorAnimation
            AutoReverse="True"
            RepeatBehavior="Forever"
            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
            To="#7F4A4A4A"
            Duration="0:0:0.5" />
    </Storyboard>

    <Style x:Key="SkeletonBlockStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="#7F313131" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource SkeletonBlockAnimation}" />
            </EventTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:UtilityCommon="clr-namespace:CBHK.Utility.Common"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton">

    <UtilityCommon:TagTextBlockWidthConverter x:Key="TagTextBlockWidthConverter" />

    <Style x:Key="TagBlockStyle" TargetType="{x:Type VectorButton:TagBlock}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type VectorButton:TagBlock}">
                    <Border Background="#1E1E1E" CornerRadius="5">
                        <Grid Height="30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                MaxWidth="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:TagRichTextBox}, Path=ActualWidth, Converter={StaticResource TagTextBlockWidthConverter}}"
                                Margin="5,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Text="{TemplateBinding Text}"
                                TextWrapping="Wrap" />
                            <VectorButton:VectorFlatIconButton
                                x:Name="CloseButton"
                                Grid.Column="1"
                                Width="25"
                                Height="25"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#D0D1D4"
                                Command="{TemplateBinding Delete}"
                                Icon="{DynamicResource CloseMark}"
                                IconBrush="Black"
                                IconHeight="20"
                                IconWidth="20"
                                Style="{DynamicResource VectorFlatIconButtonStyle}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
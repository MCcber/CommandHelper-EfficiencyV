<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton">

    <Style x:Key="VectorIconRepeatButtonStyle" TargetType="{x:Type VectorButton:VectorIconRepeatButton}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type VectorButton:VectorIconRepeatButton}">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Black"
                        BorderThickness="1"
                        SnapsToDevicePixels="true">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.5" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2.5" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2.5" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2.5" />
                                <RowDefinition x:Name="extraBottomLine" />
                            </Grid.RowDefinitions>
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Fill="{TemplateBinding LeftTopBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="2"
                                Fill="{TemplateBinding BorderCornerBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="1"
                                Grid.Column="0"
                                Fill="{TemplateBinding LeftTopBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="1"
                                Grid.Column="2"
                                Fill="{TemplateBinding RightBottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="2"
                                Grid.Column="0"
                                Fill="{TemplateBinding BorderCornerBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Fill="{TemplateBinding RightBottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="3"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Fill="{TemplateBinding BottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <Grid
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                RenderOptions.ClearTypeHint="Enabled"
                                RenderOptions.EdgeMode="Unspecified"
                                RenderTransformOrigin="0.5,0.5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="2" />
                                </Grid.RowDefinitions>
                                <Grid.RenderTransform>
                                    <RotateTransform Angle="{Binding IconAngle, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=VectorButton:VectorIconRepeatButton}}" />
                                </Grid.RenderTransform>
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <Rectangle
                                    Grid.Row="3"
                                    Grid.Column="3"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="4"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="5"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="6"
                                    Width="2"
                                    Height="2"
                                    Fill="{TemplateBinding IconBrush}" />
                                <ContentPresenter
                                    x:Name="contentPresenter"
                                    Grid.RowSpan="4"
                                    Grid.ColumnSpan="7"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Focusable="False"
                                    RecognizesAccessKey="True"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
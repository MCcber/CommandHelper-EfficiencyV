<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:utility="clr-namespace:CBHK.Utility.Common">

    <utility:DivisionConverter x:Key="DivisionConverter" />

    <Style x:Key="VectorToggleTextButtonStyle" TargetType="{x:Type VectorButton:VectorToggleTextButton}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type VectorButton:VectorToggleTextButton}">
                    <Border
                        x:Name="templateRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.5" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2.5" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2.5" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="2.5" />
                                <RowDefinition x:Name="extraBottomLine" />
                            </Grid.RowDefinitions>
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="0"
                                Fill="{TemplateBinding LeftTopBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="1"
                                Fill="{TemplateBinding LeftTopBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="2"
                                Fill="{TemplateBinding BorderCornerBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="1"
                                Grid.Column="0"
                                Fill="{TemplateBinding LeftTopBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="1"
                                Grid.Column="2"
                                Fill="{TemplateBinding RightBottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="2"
                                Grid.Column="0"
                                Fill="{TemplateBinding BorderCornerBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="2"
                                Grid.Column="1"
                                Fill="{TemplateBinding RightBottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="2"
                                Grid.Column="2"
                                Fill="{TemplateBinding RightBottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <Rectangle
                                Grid.Row="2"
                                Grid.Column="1"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=VectorButton:VectorToggleTextButton}, Converter={StaticResource DivisionConverter}, ConverterParameter=2}"
                                Height="2.5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Fill="{TemplateBinding CheckedMarkerBrush}"
                                IsHitTestVisible="False"
                                Visibility="{TemplateBinding IsShowCheckedMarker}" />
                            <Rectangle
                                Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Fill="{TemplateBinding BottomBorderBrush}"
                                IsHitTestVisible="False" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Background="Transparent"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontStyle="{TemplateBinding FontStyle}"
                                FontWeight="{TemplateBinding FontWeight}"
                                Foreground="{TemplateBinding Foreground}"
                                IsHitTestVisible="False"
                                Text="{TemplateBinding Text}"
                                TextAlignment="Center" />
                            <ContentPresenter
                                x:Name="contentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers />
    </Style>
</ResourceDictionary>
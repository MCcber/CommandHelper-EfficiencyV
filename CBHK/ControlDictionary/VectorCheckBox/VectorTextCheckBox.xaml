<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:VectorCheckBox="clr-namespace:CBHK.CustomControl.VectorCheckBox">

    <ControlTemplate x:Key="VectorTextCheckBoxTemplate" TargetType="{x:Type VectorCheckBox:VectorTextCheckBox}">
        <Grid
            x:Name="templateRoot"
            Background="Transparent"
            SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                x:Name="checkBoxBorder"
                Grid.Column="0"
                Width="15"
                Height="15"
                Margin="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                BorderBrush="Black"
                BorderThickness="{TemplateBinding BorderThickness}"
                RenderOptions.BitmapScalingMode="Unspecified"
                RenderOptions.EdgeMode="Aliased"
                RenderTransformOrigin="0.5 0.5">
                <Grid x:Name="markGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2.5" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2.5" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2.5" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        BorderBrush="{TemplateBinding InnerBorderBrush}"
                        BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="0"
                                Fill="{TemplateBinding InnerLeftTopBackground}"
                                Stroke="{TemplateBinding InnerLeftTopBackground}"
                                StrokeThickness="1" />
                            <Rectangle
                                Grid.Row="0"
                                Grid.Column="1"
                                Fill="{TemplateBinding InnerRightTopBackground}"
                                Stroke="{TemplateBinding InnerRightTopBackground}"
                                StrokeThickness="1" />
                            <Rectangle
                                Grid.Row="1"
                                Grid.Column="0"
                                Fill="{TemplateBinding InnerLeftBottomBackground}"
                                Stroke="{TemplateBinding InnerLeftBottomBackground}"
                                StrokeThickness="1" />
                            <Rectangle
                                Grid.Row="1"
                                Grid.Column="1"
                                Fill="{TemplateBinding InnerRightBottomBackground}"
                                Stroke="{TemplateBinding InnerRightBottomBackground}"
                                StrokeThickness="1" />
                        </Grid>
                    </Border>
                    <Rectangle
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Fill="{TemplateBinding LeftTopBorderBrush}"
                        Stroke="{TemplateBinding LeftTopBorderBrush}"
                        StrokeThickness="1" />
                    <Rectangle
                        Grid.Row="0"
                        Grid.Column="2"
                        Fill="{TemplateBinding BorderCornerBrush}"
                        Stroke="{TemplateBinding BorderCornerBrush}"
                        StrokeThickness="1" />
                    <Rectangle
                        Grid.Row="1"
                        Grid.Column="0"
                        Fill="{TemplateBinding LeftTopBorderBrush}"
                        Stroke="{TemplateBinding LeftTopBorderBrush}"
                        StrokeThickness="1" />
                    <Rectangle
                        Grid.Row="2"
                        Grid.Column="0"
                        Fill="{TemplateBinding BorderCornerBrush}"
                        Stroke="{TemplateBinding BorderCornerBrush}"
                        StrokeThickness="1" />
                    <Rectangle
                        Grid.Row="1"
                        Grid.Column="2"
                        Fill="{TemplateBinding RightBottomBorderBrush}"
                        Stroke="{TemplateBinding RightBottomBorderBrush}"
                        StrokeThickness="1" />
                    <Rectangle
                        Grid.Row="2"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Fill="{TemplateBinding RightBottomBorderBrush}"
                        Stroke="{TemplateBinding RightBottomBorderBrush}"
                        StrokeThickness="1" />
                </Grid>
                <Border.RenderTransform>
                    <TransformGroup>
                        <RotateTransform Angle="45" />
                    </TransformGroup>
                </Border.RenderTransform>
            </Border>
            <TextBlock
                x:Name="PART_Text"
                Grid.Column="1"
                Margin="5,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Foreground="{TemplateBinding Foreground}"
                Text="{TemplateBinding Text}" />
            <ContentPresenter
                x:Name="contentPresenter"
                Grid.ColumnSpan="2"
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                Focusable="False"
                RecognizesAccessKey="True"
                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="Text" Value="{x:Null}">
                <Setter TargetName="PART_Text" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="Text" Value="">
                <Setter TargetName="PART_Text" Property="Visibility" Value="Collapsed" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <SolidColorBrush x:Key="OptionMark.Static.Background" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="OptionMark.Static.Border" Color="#FF707070" />
    <SolidColorBrush x:Key="OptionMark.Static.Glyph" Color="#FF212121" />
    <SolidColorBrush x:Key="OptionMark.MouseOver.Background" Color="#FFF3F9FF" />
    <SolidColorBrush x:Key="OptionMark.MouseOver.Border" Color="#FF5593FF" />
    <SolidColorBrush x:Key="OptionMark.MouseOver.Glyph" Color="#FF212121" />
    <SolidColorBrush x:Key="OptionMark.Pressed.Background" Color="#FFD9ECFF" />
    <SolidColorBrush x:Key="OptionMark.Pressed.Border" Color="#FF3C77DD" />
    <SolidColorBrush x:Key="OptionMark.Pressed.Glyph" Color="#FF212121" />
    <SolidColorBrush x:Key="OptionMark.Disabled.Background" Color="#FFE6E6E6" />
    <SolidColorBrush x:Key="OptionMark.Disabled.Border" Color="#FFBCBCBC" />
    <SolidColorBrush x:Key="OptionMark.Disabled.Glyph" Color="#FF707070" />
    <Style x:Key="VectorTextCheckBoxStyle" TargetType="{x:Type VectorCheckBox:VectorTextCheckBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="{StaticResource OptionMark.Static.Background}" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
        <Setter Property="UseLayoutRounding" Value="False" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template" Value="{StaticResource VectorTextCheckBoxTemplate}" />
    </Style>
</ResourceDictionary>
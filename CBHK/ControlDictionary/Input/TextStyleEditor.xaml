                                Style="{DynamicResource VectorScrollViewerStyle}"
                                VerticalScrollBarVisibility="Auto">
                                <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

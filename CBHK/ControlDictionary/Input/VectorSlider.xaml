<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input">

    <ControlTemplate x:Key="SliderThumbHorizontalDefault" TargetType="{x:Type Thumb}">
        <Border
            Background="{Binding ThumbBackground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
            BorderBrush="Black"
            BorderThickness="2"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
            <Grid
                ClipToBounds="False"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.5" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="2.5" />
                    <RowDefinition x:Name="extraBottomLine" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2.5" />
                </Grid.ColumnDefinitions>
                <Rectangle
                    Grid.Row="0"
                    Grid.Column="0"
                    Fill="{Binding ThumbRoundBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="0"
                    Grid.Column="1"
                    Fill="{Binding ThumbRoundBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="0"
                    Grid.Column="2"
                    Fill="{Binding ThumbBorderCornerBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Fill="{Binding ThumbRoundBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="2"
                    Fill="{Binding ThumbRoundBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="2"
                    Grid.Column="0"
                    Fill="{Binding ThumbBorderCornerBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="2"
                    Grid.Column="1"
                    Fill="{Binding ThumbRoundBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="2"
                    Grid.Column="2"
                    Fill="{Binding ThumbRoundBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
                <Rectangle
                    Grid.Row="3"
                    Grid.ColumnSpan="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Fill="{Binding ThumbBottomBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorSlider}}"
                    IsHitTestVisible="False" />
            </Grid>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="SliderHorizontal" TargetType="{x:Type Input:VectorSlider}">
        <Border
            x:Name="border"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            SnapsToDevicePixels="True">
            <Grid>
                <Border
                    Height="{TemplateBinding SlidingAreaHeight}"
                    Panel.ZIndex="0"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="2" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2" />
                        </Grid.ColumnDefinitions>
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="2"
                            Fill="{TemplateBinding BackgroundBorderCornerBrush}" />
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="0"
                            Fill="{TemplateBinding BackgroundBorderCornerBrush}" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="1"
                            Fill="{TemplateBinding Background}" />
                        <Rectangle
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Fill="{TemplateBinding BackgroundRoundBorderBrush}" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="0"
                            Fill="{TemplateBinding BackgroundRoundBorderBrush}" />
                        <Rectangle
                            Grid.Row="1"
                            Grid.Column="2"
                            Fill="{TemplateBinding BackgroundRoundBorderBrush}" />
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="1"
                            Fill="{TemplateBinding BackgroundBottomBorderBrush}" />
                    </Grid>
                </Border>
                <Track
                    x:Name="PART_Track"
                    Panel.ZIndex="1"
                    IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="Transparent" BorderThickness="0">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="Transparent" BorderThickness="0">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb
                            x:Name="Thumb"
                            Width="{TemplateBinding ThumbWidth}"
                            Height="{TemplateBinding ThumbHeight}"
                            VerticalAlignment="Center"
                            Focusable="False"
                            OverridesDefaultStyle="True"
                            Template="{StaticResource SliderThumbHorizontalDefault}" />
                    </Track.Thumb>
                </Track>
            </Grid>
        </Border>
    </ControlTemplate>


    <Style x:Key="VectorSliderStyle" TargetType="{x:Type Input:VectorSlider}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ThumbWidth" Value="30" />
        <Setter Property="ThumbHeight" Value="30" />
        <Setter Property="SlidingAreaHeight" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource CommonForeground}" />
        <Setter Property="Template" Value="{StaticResource SliderHorizontal}" />
        <!--<Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Template" Value="{StaticResource SliderVertical}" />
            </Trigger>
        </Style.Triggers>-->
    </Style>
</ResourceDictionary>
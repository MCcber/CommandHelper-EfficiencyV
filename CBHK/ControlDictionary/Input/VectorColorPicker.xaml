<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors">

    <Style x:Key="ColorPickerThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Ellipse
                            Width="16"
                            Height="16"
                            Fill="Transparent"
                            Stroke="White"
                            StrokeThickness="2" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VectorColorPickerStyle" TargetType="{x:Type Input:VectorColorPicker}">
        <Style.Setters>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Input:VectorColorPicker}">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <VectorButton:VectorTextButton
                                x:Name="PickerToggle"
                                Background="{TemplateBinding Background}"
                                Foreground="{DynamicResource CommonForeground}"
                                Style="{DynamicResource VectorTextButtonStyle}"
                                Text="{TemplateBinding Title}" />
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsShowColorPopup}"
                                Placement="Center"
                                PlacementTarget="{Binding ElementName=PickerToggle}"
                                StaysOpen="True">
                                <Border
                                    Padding="5"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Black"
                                    BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="200" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid
                                            x:Name="PaletteArea"
                                            Grid.Row="0"
                                            Margin="10"
                                            ClipToBounds="True">
                                            <Rectangle x:Name="ColorBase" Fill="Red" />
                                            <Rectangle>
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Offset="0" Color="White" />
                                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <Rectangle>
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Offset="0" Color="#00000000" />
                                                        <GradientStop Offset="1" Color="Black" />
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <Canvas>
                                                <Thumb
                                                    x:Name="PaletteThumb"
                                                    Canvas.Left="0"
                                                    Canvas.Top="0"
                                                    Style="{StaticResource ColorPickerThumbStyle}" />
                                            </Canvas>
                                        </Grid>
                                        <Grid
                                            Grid.Row="1"
                                            Height="20"
                                            Margin="10,0,10,10">
                                            <Rectangle RadiusX="5" RadiusY="5">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Offset="0.0" Color="#FF0000" />
                                                        <GradientStop Offset="0.166" Color="#FFFF00" />
                                                        <GradientStop Offset="0.333" Color="#00FF00" />
                                                        <GradientStop Offset="0.5" Color="#00FFFF" />
                                                        <GradientStop Offset="0.666" Color="#0000FF" />
                                                        <GradientStop Offset="0.833" Color="#FF00FF" />
                                                        <GradientStop Offset="1.0" Color="#FF0000" />
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>
                                            <Canvas x:Name="HueCanvas" Background="Transparent">
                                                <Thumb
                                                    x:Name="HueThumb"
                                                    Canvas.Left="0"
                                                    Canvas.Top="-2"
                                                    Width="8"
                                                    Height="24"
                                                    Background="#D0D1D4"
                                                    BorderBrush="Black"
                                                    BorderThickness="1" />
                                            </Canvas>
                                        </Grid>
                                        <Grid Grid.Row="2" Margin="10,0,10,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Width="40"
                                                Height="30"
                                                Background="{Binding SelectedColorBrush, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                BorderBrush="Gray"
                                                BorderThickness="1"
                                                CornerRadius="5" />
                                            <VectorButton:VectorFlatIconButton
                                                x:Name="Eyedropper"
                                                Grid.Column="1"
                                                Width="30"
                                                Height="30"
                                                Margin="10,0,0,0"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Icon="M19.35,11.72L17.22,13.85L15.81,12.43L8.1,20.14L3.5,22L5.36,17.4L13.07,9.7L11.66,8.28L13.78,6.16C14.17,5.77 14.8,5.77 15.19,6.16L19.35,10.31C19.74,10.7 19.74,11.33 19.35,11.72M10.22,18.73L6.96,18.04L7.65,14.78L15.1,7.33L17.67,9.9L10.22,18.73Z"
                                                IconBrush="White"
                                                IconHeight="16"
                                                IconWidth="16"
                                                Style="{DynamicResource VectorFlatIconButtonStyle}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontFamily="Consolas"
                                                FontSize="14"
                                                Foreground="White"
                                                Text="{Binding HexCode, RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>
    </Style>
</ResourceDictionary>
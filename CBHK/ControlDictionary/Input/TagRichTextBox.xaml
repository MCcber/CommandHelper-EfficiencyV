<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:TextElement="clr-namespace:CBHK.CustomControl.TextElement"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors">
    <Style x:Key="TagRichTextBoxStyle" TargetType="{x:Type Input:TagRichTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Input:TagRichTextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Input:VectorTextBox
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            Background="#323334"
                            BorderBrush="#424242"
                            BorderThickness="1"
                            CaretBrush="White"
                            FontSize="15"
                            Foreground="White"
                            Style="{DynamicResource VectorTextBoxStyle}"
                            WaterMarkerBrush="Gray"
                            WaterMarkerMargin="5 0 0 0"
                            WaterMarkerText="输入后按下回车创建标签">
                            <behaviors:Interaction.Triggers>
                                <behaviors:EventTrigger EventName="KeyDown">
                                    <behaviors:CallMethodAction MethodName="TextBox_KeyDown" TargetObject="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:TagRichTextBox}}" />
                                </behaviors:EventTrigger>
                            </behaviors:Interaction.Triggers>
                        </Input:VectorTextBox>
                        <RichTextBox
                            x:Name="tagBox"
                            Grid.Row="1"
                            Background="#565A57"
                            BorderThickness="0"
                            CaretBrush="White"
                            Foreground="White"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            VerticalScrollBarVisibility="Auto">
                            <behaviors:Interaction.Triggers>
                                <behaviors:EventTrigger EventName="Loaded">
                                    <behaviors:CallMethodAction MethodName="ContentRichTextBox_Loaded" TargetObject="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:TagRichTextBox}}" />
                                </behaviors:EventTrigger>
                            </behaviors:Interaction.Triggers>
                            <TextElement:EnabledFlowDocument>
                                <Paragraph />
                            </TextElement:EnabledFlowDocument>
                        </RichTextBox>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
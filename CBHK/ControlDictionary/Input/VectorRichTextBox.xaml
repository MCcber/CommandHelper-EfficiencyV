    <Style x:Key="VectorRichTextBoxStyle" TargetType="{x:Type Input:VectorRichTextBox}">
        <Style.Resources>
            <Style x:Key="{x:Type FlowDocument}" TargetType="{x:Type FlowDocument}">
                <Setter Property="OverridesDefaultStyle" Value="true" />
            </Style>
            <!--<Style x:Key="{x:Type Hyperlink}" TargetType="{x:Type Input:VectorRichTextBox}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="true">
                        <Setter Property="Foreground" Value="Blue" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="false">
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Trigger>
                </Style.Triggers>
            </Style>-->
        </Style.Resources>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Input:VectorRichTextBox">
                    <Border
                        x:Name="border"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="2"
                        SnapsToDevicePixels="True">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="5" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Rectangle Grid.Row="0" Fill="{TemplateBinding LocateLineBrush}" />
                            <Container:VectorScrollViewer
                                x:Name="PART_ContentHost"
                                Grid.Row="1"
                                Panel.ZIndex="1"
                                Focusable="false"
                                HorizontalScrollBarVisibility="Auto"
                                IsAllowDragToScroll="False"
                                Style="{DynamicResource VectorScrollViewerStyle}"
                                VerticalScrollBarVisibility="Auto" />
                            <TextBlock
                                x:Name="waterMarker"
                                Grid.Row="1"
                                Margin="{TemplateBinding WaterMarkerMargin}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Panel.ZIndex="0"
                                Background="Transparent"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{Binding WaterMarkerBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorRichTextBox}}"
                                Text="{Binding WaterMarkerText, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Input:VectorRichTextBox}}"
                                TextAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasText" Value="False">
                            <Setter TargetName="waterMarker" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasText" Value="True">
                            <Setter TargetName="waterMarker" Property="Visibility" Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="MinWidth" Value="10" />
    </Style>
</ResourceDictionary>
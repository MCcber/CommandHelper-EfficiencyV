<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:behavior="http://schemas.microsoft.com/xaml/behaviors">

    <Style x:Key="TimelineClipStyle" TargetType="{x:Type Input:TimelineClip}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Input:TimelineClip}">
                    <Grid Background="Transparent">
                        <Border
                            x:Name="singleFrameBorder"
                            Width="{TemplateBinding PointModeSize}"
                            Height="{TemplateBinding PointModeSize}"
                            BorderBrush="Black"
                            BorderThickness="1"
                            RenderOptions.BitmapScalingMode="Unspecified"
                            RenderOptions.EdgeMode="Aliased"
                            RenderTransformOrigin="0.5 0.5">
                            <Grid x:Name="markGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2.5" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="2.5" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2.5" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    BorderBrush="{TemplateBinding InnerBorderBrush}"
                                    BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Fill="{TemplateBinding InnerLeftTopBackground}"
                                            Stroke="{TemplateBinding InnerLeftTopBackground}"
                                            StrokeThickness="1" />
                                        <Rectangle
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Fill="{TemplateBinding InnerRightTopBackground}"
                                            Stroke="{TemplateBinding InnerRightTopBackground}"
                                            StrokeThickness="1" />
                                        <Rectangle
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Fill="{TemplateBinding InnerLeftBottomBackground}"
                                            Stroke="{TemplateBinding InnerLeftBottomBackground}"
                                            StrokeThickness="1" />
                                        <Rectangle
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Fill="{TemplateBinding InnerRightBottomBackground}"
                                            Stroke="{TemplateBinding InnerRightBottomBackground}"
                                            StrokeThickness="1" />
                                    </Grid>
                                </Border>
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Fill="{TemplateBinding LeftTopBorderBrush}"
                                    Stroke="{TemplateBinding LeftTopBorderBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Fill="{TemplateBinding BorderCornerBrush}"
                                    Stroke="{TemplateBinding BorderCornerBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Fill="{TemplateBinding LeftTopBorderBrush}"
                                    Stroke="{TemplateBinding LeftTopBorderBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Fill="{TemplateBinding BorderCornerBrush}"
                                    Stroke="{TemplateBinding BorderCornerBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Fill="{TemplateBinding RightBottomBorderBrush}"
                                    Stroke="{TemplateBinding RightBottomBorderBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Fill="{TemplateBinding RightBottomBorderBrush}"
                                    Stroke="{TemplateBinding RightBottomBorderBrush}"
                                    StrokeThickness="1" />
                            </Grid>
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <TranslateTransform X="-5" Y="8" />
                                    <RotateTransform Angle="45" />
                                </TransformGroup>
                            </Border.RenderTransform>
                        </Border>
                        <Border
                            x:Name="multipleFrameBorder"
                            Background="#D0D1D4"
                            BorderThickness="0"
                            Visibility="Hidden">
                            <Grid Width="{Binding RectangleModeWidth, RelativeSource={RelativeSource Mode=TemplatedParent}}" Height="{Binding RectangleModeHeight, RelativeSource={RelativeSource Mode=TemplatedParent}}">
                                <Container:ContinuousKeyframeItem
                                    Width="8"
                                    Height="8"
                                    HorizontalAlignment="Left"
                                    Panel.ZIndex="1"
                                    Style="{DynamicResource ContinuousKeyframeItemStyle}" />
                                <Container:ContinuousKeyframeItem
                                    Width="8"
                                    Height="8"
                                    HorizontalAlignment="Right"
                                    Panel.ZIndex="1"
                                    Style="{DynamicResource ContinuousKeyframeItemStyle}" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Panel.ZIndex="1"
                                    Background="Transparent"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding Title}" />
                                <Input:VectorTextBox
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Top"
                                    Panel.ZIndex="1"
                                    AcceptsReturn="False"
                                    AcceptsTab="True"
                                    Background="Transparent"
                                    Foreground="{TemplateBinding Foreground}"
                                    Style="{DynamicResource VectorTextBoxStyle}"
                                    Text="{TemplateBinding Title}"
                                    Visibility="{TemplateBinding TitleEditorVisibility}" />
                                <TextBlock
                                    Margin="0,0,10,2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Panel.ZIndex="1"
                                    Background="Transparent"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding DurationText}" />
                                <Canvas
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Panel.ZIndex="0">
                                    <behavior:Interaction.Triggers>
                                        <behavior:EventTrigger EventName="Loaded">
                                            <behavior:CallMethodAction MethodName="ScaleTime_Loaded" TargetObject="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                        </behavior:EventTrigger>
                                    </behavior:Interaction.Triggers>
                                </Canvas>
                            </Grid>
                        </Border>
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Grid.ColumnSpan="2"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Focusable="False"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="CurrentClipMode" Value="Rectangle">
                            <Setter TargetName="singleFrameBorder" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="multipleFrameBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:behavior="http://schemas.microsoft.com/xaml/behaviors">
    <Style x:Key="TimelineKeyFrameStyle" TargetType="{x:Type Input:TimelineKeyFrame}">
        <Setter Property="Panel.ZIndex" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Input:TimelineClip}">
                    <Grid
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        HorizontalAlignment="Left"
                        Background="Transparent">
                        <Border
                            BorderBrush="Black"
                            BorderThickness="1"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            RenderOptions.EdgeMode="Aliased"
                            RenderTransformOrigin="0.5 0.5">
                            <Grid x:Name="markGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2.5" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="2.5" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2.5" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    BorderBrush="{TemplateBinding InnerBorderBrush}"
                                    BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Fill="{TemplateBinding InnerLeftTopBackground}"
                                            Stroke="{TemplateBinding InnerLeftTopBackground}"
                                            StrokeThickness="1" />
                                        <Rectangle
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Fill="{TemplateBinding InnerRightTopBackground}"
                                            Stroke="{TemplateBinding InnerRightTopBackground}"
                                            StrokeThickness="1" />
                                        <Rectangle
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Fill="{TemplateBinding InnerLeftBottomBackground}"
                                            Stroke="{TemplateBinding InnerLeftBottomBackground}"
                                            StrokeThickness="1" />
                                        <Rectangle
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Fill="{TemplateBinding InnerRightBottomBackground}"
                                            Stroke="{TemplateBinding InnerRightBottomBackground}"
                                            StrokeThickness="1" />
                                    </Grid>
                                </Border>
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Fill="{TemplateBinding LeftTopBorderBrush}"
                                    Stroke="{TemplateBinding LeftTopBorderBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Fill="{TemplateBinding BorderCornerBrush}"
                                    Stroke="{TemplateBinding BorderCornerBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Fill="{TemplateBinding LeftTopBorderBrush}"
                                    Stroke="{TemplateBinding LeftTopBorderBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Fill="{TemplateBinding BorderCornerBrush}"
                                    Stroke="{TemplateBinding BorderCornerBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Fill="{TemplateBinding RightBottomBorderBrush}"
                                    Stroke="{TemplateBinding RightBottomBorderBrush}"
                                    StrokeThickness="1" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Fill="{TemplateBinding RightBottomBorderBrush}"
                                    Stroke="{TemplateBinding RightBottomBorderBrush}"
                                    StrokeThickness="1" />
                            </Grid>
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <TranslateTransform X="-5" Y="8" />
                                    <RotateTransform Angle="45" />
                                </TransformGroup>
                            </Border.RenderTransform>
                        </Border>
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Grid.ColumnSpan="2"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Focusable="False"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
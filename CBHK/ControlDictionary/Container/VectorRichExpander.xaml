<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton">

    <Style x:Key="ExpanderDownHeaderStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border BorderBrush="Transparent" BorderThickness="0">
                        <Grid Background="{Binding Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3.5" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="3.5" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3.5" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="3.5" />
                                </Grid.RowDefinitions>
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Fill="{Binding LeftTopBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Fill="{Binding LeftTopBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Fill="{Binding BorderCornerBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Fill="{Binding LeftTopBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Fill="{Binding RightBottomBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Fill="{Binding BorderCornerBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Fill="{Binding RightBottomBorderBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                    IsHitTestVisible="False" />
                            </Grid>
                            <Grid
                                Grid.Column="1"
                                Margin="{Binding ArrowMargin, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5 0.5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="2" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="2" />
                                </Grid.RowDefinitions>
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform Angle="{Binding RotationAngle, RelativeSource={RelativeSource AncestorType=Container:VectorRichExpander}}" />
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                                <Rectangle
                                    Grid.Row="3"
                                    Grid.Column="3"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                                <Rectangle
                                    Grid.Row="2"
                                    Grid.Column="4"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                                <Rectangle
                                    Grid.Row="1"
                                    Grid.Column="5"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                                <Rectangle
                                    Grid.Row="0"
                                    Grid.Column="6"
                                    Width="2"
                                    Height="2"
                                    Fill="{Binding ArrowBrush, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorRichExpander}}" />
                            </Grid>
                            <ContentPresenter
                                Grid.Column="0"
                                Margin="6"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Panel.ZIndex="1"
                                RecognizesAccessKey="True"
                                SnapsToDevicePixels="True" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


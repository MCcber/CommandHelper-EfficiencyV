<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors">
    <Style x:Key="EyedropperWindowStyle" TargetType="{x:Type Container:EyedropperWindow}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="Topmost" Value="True" />
        <Setter Property="Cursor" Value="Cross" />
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="ShowInTaskbar" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Container:EyedropperWindow}">
                    <Canvas x:Name="OverlayCanvas" Background="Transparent">
                        <Grid
                            x:Name="MagnifierGrid"
                            Width="120"
                            Height="120">
                            <Grid.Clip>
                                <EllipseGeometry
                                    Center="60,60"
                                    RadiusX="60"
                                    RadiusY="60" />
                            </Grid.Clip>
                            <Ellipse
                                Width="120"
                                Height="120"
                                Stroke="White"
                                StrokeThickness="4" />
                            <Ellipse
                                Width="114"
                                Height="114"
                                Margin="3"
                                Stroke="{DynamicResource CommonForeground}"
                                StrokeThickness="1" />
                            <Border x:Name="PreviewColorBox" Background="Transparent" />
                            <Path
                                Data="M 60,40 V 80 M 40,60 H 80"
                                Opacity="0.5"
                                Stroke="Black"
                                StrokeThickness="1" />
                            <Path
                                Margin="1,1,0,0"
                                Data="M 60,40 V 80 M 40,60 H 80"
                                Opacity="0.5"
                                Stroke="White"
                                StrokeThickness="1" />
                        </Grid>
                    </Canvas>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataTemplate x:Key="MessageTipItemTemplate">
        <Border
            Background="{Binding SecondBackground}"
            BorderBrush="Black"
            BorderThickness="2"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Rectangle
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="2"
                    Margin="4,6"
                    Panel.ZIndex="0"
                    Fill="{Binding FirstBackground}" />
                <Rectangle
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="2"
                    Margin="6,4"
                    Panel.ZIndex="0"
                    Fill="{Binding FirstBackground}" />
                <Image
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    Width="30"
                    Height="30"
                    Margin="10,10,5,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Panel.ZIndex="1"
                    Source="{Binding Icon}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5,2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="1"
                    Foreground="{Binding MessageBrush}"
                    Text="{Binding Message}"
                    TextWrapping="WrapWithOverflow" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5,2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Panel.ZIndex="1"
                    Foreground="{Binding SubMessageBrush}"
                    Text="{Binding SubMessage}"
                    TextWrapping="WrapWithOverflow" />
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
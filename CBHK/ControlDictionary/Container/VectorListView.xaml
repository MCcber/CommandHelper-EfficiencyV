<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container">

    <!--  需要在外部设置ItemTemplate布局  -->
    <Style x:Key="VectorListViewStyle" TargetType="{x:Type Container:VectorListView}">
        <Setter Property="ItemContainerStyle" Value="{DynamicResource VectorListViewItemContainerStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Container:VectorListView}">
                    <Border
                        x:Name="Bd"
                        Padding="1"
                        Background="Transparent"
                        BorderBrush="Black"
                        BorderThickness="1"
                        SnapsToDevicePixels="true">
                        <Container:VectorScrollViewer
                            Focusable="false"
                            Style="{DynamicResource VectorScrollViewerStyle}"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.ScrollUnit="Pixel"
                            VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsPresenter
                                x:Name="itemPresenter"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                RenderOptions.ClearTypeHint="Enabled" />
                        </Container:VectorScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
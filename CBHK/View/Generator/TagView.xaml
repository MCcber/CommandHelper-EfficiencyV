<Container:VectorWindow
    x:Class="CBHK.View.Generator.TagView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:VectorCheckBox="clr-namespace:CBHK.CustomControl.VectorCheckBox"
    xmlns:VectorComboBox="clr-namespace:CBHK.CustomControl.VectorComboBox"
    xmlns:behavior="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:utility="clr-namespace:CBHK.Utility.Visual"
    Title="标签生成器"
    Width="835"
    Height="530"
    MinWidth="835"
    MinHeight="530"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="#2F2F2F"
    Foreground="White"
    Icon="/CBHK;component/Resource/Common/Image/SpawnerIcon/IconTags.png"
    IconMargin="5"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <CollectionViewSource x:Key="TagItemSource" Source="{Binding TagItemList, IsAsync=True}" />
        <ImageBrush x:Key="ButtonNormal" ImageSource="/CBHK;component/Resource/Common/Image/ButtonNormal.png" />
        <ImageBrush x:Key="ButtonPressed" ImageSource="/CBHK;component/Resource/Common/Image/ButtonPressed.png" />
        <ImageBrush x:Key="EditBox" ImageSource="/CBHK;component/Resource/Common/Image/TextEditBox.png" />
        <ImageBrush x:Key="Issue" ImageSource="/CBHK;component/Resource/Common/Image/Issue.png" />
        <ImageBrush x:Key="LeftArrow" ImageSource="/CBHK;component/Resource/Common/Image/IconArrowLeft.png" />
        <ImageBrush x:Key="RightArrow" ImageSource="/CBHK;component/Resource/Common/Image/IconArrowRight.png" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
        <KeyBinding
            Key="Esc"
            Command="{Binding ReturnCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}" />
    </Window.InputBindings>

    <behavior:Interaction.Triggers>
        <behavior:EventTrigger EventName="Loaded">
            <behavior:CallMethodAction MethodName="TagView_Loaded" TargetObject="{Binding}" />
        </behavior:EventTrigger>
    </behavior:Interaction.Triggers>

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Height="35">
            <VectorButton:VectorFlatImageButton
                Command="{Binding ReturnCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}"
                Image="/Resource/Common/Image/IconArrowLeft.png"
                ImageMargin="5"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="ESC:返回主页"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorButton:VectorFlatImageButton
                Command="{Binding RunCommand}"
                Image="/Resource/Common/Image/IconArrowRight.png"
                ImageMargin="5"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="F5:运行"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorCheckBox:VectorTextCheckBox
                Margin="5,0,0,0"
                Foreground="White"
                IsChecked="{Binding Replace, Mode=TwoWay}"
                Style="{DynamicResource VectorTextCheckBoxStyle}"
                Text="替换"
                ToolTip="Replace"
                ToolTipService.InitialShowDelay="0"
                ToolTipService.ShowDuration="3000" />
            <VectorCheckBox:VectorTextCheckBox
                Margin="5,0,0,0"
                Foreground="White"
                IsChecked="{Binding SelectedAll, Mode=OneWayToSource}"
                Style="{DynamicResource VectorTextCheckBoxStyle}"
                Text="全选">
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="Click">
                        <behavior:CallMethodAction MethodName="SelectAll_Click" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </VectorCheckBox:VectorTextCheckBox>
            <VectorCheckBox:VectorTextCheckBox
                Margin="5,0,0,0"
                Foreground="White"
                IsChecked="{Binding ReverseAll, Mode=OneWayToSource}"
                Style="{DynamicResource VectorTextCheckBoxStyle}"
                Text="反选">
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="Click">
                        <behavior:CallMethodAction MethodName="ReverseAll_Click" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </VectorCheckBox:VectorTextCheckBox>
            <VectorComboBox:VectorTextComboBox
                Title="数据类型"
                MinWidth="80"
                Margin="5,0,0,0"
                ArrowMargin="0 2 5 0"
                BorderBrush="Black"
                Foreground="White"
                IsReadOnly="True"
                ItemsSource="{Binding TypeItemSource, IsAsync=True}"
                SelectedItem="{Binding SelectedTypeItem, Mode=TwoWay}"
                Style="{DynamicResource VectorTextComboBoxStyle}">
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="SelectionChanged">
                        <behavior:CallMethodAction MethodName="TypeBox_SelectionChanged" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </VectorComboBox:VectorTextComboBox>
            <VectorComboBox:VectorTextComboBox
                Title="版本"
                Width="80"
                ArrowMargin="0 2 5 0"
                BorderBrush="Black"
                Foreground="White"
                IsReadOnly="True"
                ItemsSource="{Binding VersionList}"
                SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                Style="{DynamicResource VectorTextComboBoxStyle}" />
            <VectorButton:VectorTextButton
                Background="#D0D1D4"
                Command="{Binding ImportFromClipboardCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="从剪切板导入" />
            <VectorButton:VectorTextButton
                Background="#D0D1D4"
                Command="{Binding ImportFromFileCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="从文件导入" />
            <Input:VectorTextBox
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Center"
                utility:TextSizeHelper.AutoFontSize="True"
                Background="#313233"
                BorderBrush="Black"
                CaretBrush="White"
                FontSize="15"
                Foreground="White"
                Style="{DynamicResource VectorTextBoxStyle}"
                Text="{Binding SearchText, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"
                TextAlignment="Left"
                WaterMarkerBrush="Gray"
                WaterMarkerMargin="5 0 0 0"
                WaterMarkerText="搜索成员">
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="TextChanged">
                        <behavior:CallMethodAction MethodName="SearchTextBox_TextChanged" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </Input:VectorTextBox>
        </DockPanel>
        <ListView
            Grid.Row="2"
            Background="#555956"
            BorderBrush="Black"
            ItemsSource="{Binding Source={StaticResource TagItemSource}, IsAsync=True}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.ScrollUnit="Pixel"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="{Binding Background, Mode=OneWay}" IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ToggleButton
                            x:Name="checkButton"
                            IsChecked="{Binding BeChecked, Mode=TwoWay}"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />
                        <Image
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="0"
                            Width="65"
                            Height="65"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            Source="{Binding Icon, IsAsync=True}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="25"
                            FontStyle="Italic"
                            IsHitTestVisible="False"
                            Text="{Binding DisplayId, IsAsync=True}"
                            TextAlignment="Left" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="25"
                            IsHitTestVisible="False"
                            Text="{Binding DisplayName, IsAsync=True}"
                            TextAlignment="Left" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel
                        Background="#555956"
                        VirtualizingPanel.CacheLengthUnit="Pixel"
                        VirtualizingPanel.IsContainerVirtualizable="True"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.ScrollUnit="Pixel"
                        VirtualizingPanel.VirtualizationMode="Recycling" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <behavior:Interaction.Triggers>
                <behavior:EventTrigger EventName="Loaded">
                    <behavior:CallMethodAction MethodName="ListViewLoaded" TargetObject="{Binding}" />
                </behavior:EventTrigger>
                <behavior:EventTrigger EventName="PreviewMouseLeftButtonUp">
                    <behavior:CallMethodAction MethodName="ListBoxClick" TargetObject="{Binding}" />
                </behavior:EventTrigger>
            </behavior:Interaction.Triggers>
        </ListView>
    </Grid>
</Container:VectorWindow>

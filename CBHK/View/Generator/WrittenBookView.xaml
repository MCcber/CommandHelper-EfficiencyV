<Container:VectorWindow
    x:Class="CBHK.View.Generator.WrittenBookView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:VectorComboBox="clr-namespace:CBHK.CustomControl.VectorComboBox"
    xmlns:behavior="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Title="成书生成器"
    Width="490"
    Height="730"
    prism:ViewModelLocator.AutoWireViewModel="True"
    ContextMenu="{x:Null}"
    Icon="/CBHK;component/Resource/Common/Image/SpawnerIcon/IconWrittenBook.png"
    IconMargin="5"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
        <KeyBinding
            Key="Esc"
            Command="{Binding ReturnCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}" />
    </Window.InputBindings>

    <Grid Background="#2F2F2F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel
            Grid.Row="0"
            Height="35"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
            <VectorButton:VectorFlatImageButton
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding ReturnCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}"
                Image="/Resource/Common/Image/IconArrowLeft.png"
                ImageMargin="5"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="ESC:返回主页"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorButton:VectorFlatImageButton
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding RunCommand}"
                Image="/Resource/Common/Image/IconArrowRight.png"
                ImageMargin="5"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="F5:运行"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <Input:VectorNumbericUpDown
                Width="130"
                Style="{DynamicResource VectorNumbericUpDownStyle}"
                Text="{Binding JumpSpecificPageNumber, Mode=OneWayToSource}"
                WaterMarkerBrush="Gray"
                WaterMarkerMargin="5 0 0 0"
                WaterMarkerText="跳转到">
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="KeyDown">
                        <behavior:CallMethodAction MethodName="JumpToSpecificPage_KeyDown" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </Input:VectorNumbericUpDown>
            <VectorComboBox:VectorTextComboBox
                Title="版本"
                Width="100"
                ArrowMargin="0 0 5 0"
                ItemsSource="{Binding VersionSource}"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedVersion}"
                Style="{DynamicResource VectorTextComboBoxStyle}">
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="SelectionChanged">
                        <behavior:CallMethodAction MethodName="Version_SelectionChanged" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </VectorComboBox:VectorTextComboBox>
            <VectorButton:VectorToggleIconTextButton
                Margin="5,0,0,0"
                Foreground="White"
                IsChecked="{Binding ShowGeneratorResult, Mode=OneWayToSource}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="显示结果" />
        </DockPanel>
        <DockPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            LastChildFill="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="63" />
                    <ColumnDefinition Width="63" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <VectorButton:VectorTextButton
                    Grid.Column="0"
                    VerticalAlignment="Bottom"
                    Background="#EFF2F1"
                    Command="{Binding BoldTextCommand}"
                    FontWeight="Bold"
                    Style="{DynamicResource VectorTextButtonStyle}"
                    Text="Bold"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <VectorButton:VectorTextButton.ToolTip>
                        <ToolTip
                            Background="#424242"
                            Content="粗体"
                            Foreground="White" />
                    </VectorButton:VectorTextButton.ToolTip>
                    <TextBlock FontWeight="Bold" Text="Bold" />
                </VectorButton:VectorTextButton>
                <VectorButton:VectorTextButton
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Background="#EFF2F1"
                    Command="{Binding ItalicTextCommand}"
                    FontStyle="Italic"
                    Style="{DynamicResource VectorTextButtonStyle}"
                    Text="Italic"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <VectorButton:VectorTextButton.ToolTip>
                        <ToolTip
                            Background="#424242"
                            Content="斜体"
                            Foreground="White" />
                    </VectorButton:VectorTextButton.ToolTip>
                    <TextBlock FontStyle="Italic" Text="Italic" />
                </VectorButton:VectorTextButton>
                <VectorButton:VectorTextButton
                    Grid.Column="2"
                    VerticalAlignment="Bottom"
                    Background="#EFF2F1"
                    Command="{Binding UnderlinedTextCommand}"
                    Style="{DynamicResource VectorTextButtonStyle}"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <VectorButton:VectorTextButton.ToolTip>
                        <ToolTip
                            Background="#424242"
                            Content="下划线"
                            Foreground="White" />
                    </VectorButton:VectorTextButton.ToolTip>
                    <TextBlock Text="Underlined">
                        <TextBlock.TextDecorations>
                            <TextDecoration />
                        </TextBlock.TextDecorations>
                    </TextBlock>
                </VectorButton:VectorTextButton>
                <VectorButton:VectorTextButton
                    Grid.Column="3"
                    VerticalAlignment="Bottom"
                    Background="#EFF2F1"
                    Command="{Binding StrikethroughTextCommand}"
                    Style="{DynamicResource VectorTextButtonStyle}"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <VectorButton:VectorTextButton.ToolTip>
                        <ToolTip
                            Background="#424242"
                            Content="删除线"
                            Foreground="White" />
                    </VectorButton:VectorTextButton.ToolTip>
                    <TextBlock Text="Strikethrough">
                        <TextBlock.TextDecorations>
                            <TextDecoration PenOffset="-5" />
                        </TextBlock.TextDecorations>
                    </TextBlock>
                </VectorButton:VectorTextButton>
                <VectorButton:VectorTextButton
                    Grid.Column="4"
                    VerticalAlignment="Bottom"
                    Background="#EFF2F1"
                    Command="{Binding ObfuscateTextCommand}"
                    Style="{DynamicResource VectorTextButtonStyle}"
                    Text="Obfuscate"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <VectorButton:VectorTextButton.ToolTip>
                        <ToolTip
                            Background="#424242"
                            Content="混淆"
                            Foreground="White" />
                    </VectorButton:VectorTextButton.ToolTip>
                </VectorButton:VectorTextButton>
                <VectorButton:VectorTextButton
                    Grid.Column="5"
                    VerticalAlignment="Bottom"
                    Background="#EFF2F1"
                    Command="{Binding ResetTextCommand}"
                    Style="{DynamicResource VectorTextButtonStyle}"
                    Text="Reset"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <VectorButton:VectorTextButton.ToolTip>
                        <ToolTip
                            Background="#424242"
                            Content="重置选定文本样式"
                            Foreground="White" />
                    </VectorButton:VectorTextButton.ToolTip>
                </VectorButton:VectorTextButton>
            </Grid>
            <Input:VectorColorPicker
                Title="设置文本颜色"
                Grid.Column="1"
                Background="Black"
                SelectedColor="{Binding SelectionColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Style="{DynamicResource VectorColorPicker}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <Input:VectorColorPicker.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="设置选定文本颜色"
                        Foreground="White" />
                </Input:VectorColorPicker.ToolTip>
                <behavior:Interaction.Triggers>
                    <behavior:EventTrigger EventName="PropertyChanged">
                        <behavior:CallMethodAction MethodName="SetSelectionColor" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                    <behavior:EventTrigger EventName="Loaded">
                        <behavior:CallMethodAction MethodName="ColorPickerLoaded" TargetObject="{Binding}" />
                    </behavior:EventTrigger>
                </behavior:Interaction.Triggers>
            </Input:VectorColorPicker>
        </DockPanel>
        <ContentControl
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch">
            <behavior:Interaction.Triggers>
                <behavior:EventTrigger EventName="Loaded">
                    <behavior:CallMethodAction MethodName="PageFrame_Loaded" TargetObject="{Binding}" />
                </behavior:EventTrigger>
            </behavior:Interaction.Triggers>
        </ContentControl>
    </Grid>

</Container:VectorWindow>
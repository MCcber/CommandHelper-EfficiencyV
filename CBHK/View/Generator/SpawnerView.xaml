<Container:VectorWindow
    x:Class="CBHK.View.Generator.SpawnerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Component="clr-namespace:CBHK.View.Generator"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:behavior="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Title="刷怪笼生成器"
    Width="790"
    Height="594"
    MinWidth="790"
    MinHeight="594"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="#2F2F2F"
    Icon="/CBHK;component/Resource/Common/Image/SpawnerIcon/IconSpawner.png"
    IconMargin="5"
    ResizeMode="CanResizeWithGrip"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="False">
            <VectorButton:VectorFlatImageButton
                Width="25"
                Height="25"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding ReturnCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}"
                FontSize="15"
                Image="/Resource/Common/Image/IconArrowLeft.png"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="ESC:返回主页"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorButton:VectorFlatImageButton
                Width="25"
                Height="25"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding RunCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}"
                FontSize="15"
                Image="/Resource/Common/Image/IconArrowRight.png"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="F5:运行"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorButton:VectorFlatImageButton
                Width="25"
                Height="25"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding SaveAllCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Container:VectorWindow}}"
                FontSize="15"
                Image="/Resource/Common/Image/Save.png"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="保存"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorButton:VectorTextButton
                Padding="5"
                Command="{Binding AddSpawnerCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="添加" />
            <VectorButton:VectorTextButton
                Padding="5"
                Command="{Binding ClearSpawnerCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="清除" />
            <VectorButton:VectorTextButton
                Padding="5"
                Command="{Binding ImportFromClipboardCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="从剪切板导入" />
            <VectorButton:VectorTextButton
                Padding="5"
                Command="{Binding ImportFromFileCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="从文件导入" />
            <VectorButton:VectorToggleIconTextButton
                Foreground="White"
                IsChecked="{Binding ShowResult, Mode=OneWayToSource}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="显示结果" />
        </DockPanel>
        <Container:VectorTabControl
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding SpawnerPageList}"
            SelectedIndex="0"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            Style="{DynamicResource VectorTabControlStyle}" />
    </Grid>
</Container:VectorWindow>

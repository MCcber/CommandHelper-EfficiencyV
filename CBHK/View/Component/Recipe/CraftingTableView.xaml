<UserControl
    x:Class="CBHK.View.Component.Recipe.CraftingTableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:VectorButtong="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:VirtualizingWrapPanel="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CBHK.View.Component.Recipe"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <CollectionViewSource x:Key="MultiModeItemViewSource" Source="{Binding CurrentMaterialCollection, IsAsync=True}" />
        <ImageBrush x:Key="CraftingTableBackground" ImageSource="/CBHK;component/Resource/Common/Image/Recipe/CraftingTable.png" />
        <ImageBrush x:Key="Frame" ImageSource="/CBHK;component/Resource/Common/Image/Frame.png" />
    </UserControl.Resources>

    <Grid
        Width="500"
        Height="260"
        Background="{StaticResource CraftingTableBackground}">
        <Grid
            Width="228"
            Margin="5,0,0,8"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="Loaded">
                    <behaviors:CallMethodAction MethodName="MaterialGrid_Loaded" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[0]}" />
            <Image
                Uid="0"
                Grid.Row="0"
                Grid.Column="0"
                Width="70"
                Height="70"
                Panel.ZIndex="0"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[1]}" />
            <Image
                Uid="1"
                Grid.Row="0"
                Grid.Column="1"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[2]}" />
            <Image
                Uid="2"
                Grid.Row="0"
                Grid.Column="2"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="1"
                Grid.Column="0"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[3]}" />
            <Image
                Uid="3"
                Grid.Row="1"
                Grid.Column="0"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[4]}" />
            <Image
                Uid="4"
                Grid.Row="1"
                Grid.Column="1"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="1"
                Grid.Column="2"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[5]}" />
            <Image
                Grid.Row="1"
                Grid.Column="2"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="2"
                Grid.Column="0"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[6]}" />
            <Image
                Grid.Row="2"
                Grid.Column="0"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="2"
                Grid.Column="1"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[7]}" />
            <Image
                Grid.Row="2"
                Grid.Column="1"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
            <Button
                Grid.Row="2"
                Grid.Column="2"
                Width="20"
                Height="20"
                Margin="0,2,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Command="{Binding SetSlotDataCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                Content="..."
                FontWeight="Bold"
                Visibility="{Binding MaterialMultiItemVisibilityList[8]}" />
            <Image
                Grid.Row="2"
                Grid.Column="2"
                Width="70"
                Height="70"
                AllowDrop="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Drop">
                        <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
        </Grid>
        <VectorButtong:VectorToggleIconTextButton
            Margin="75,10,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsChecked="{Binding Shaped, Mode=TwoWay}"
            Style="{DynamicResource VectorToggleIconTextButtonStyle}"
            Text="有序" />
        <VectorButtong:VectorToggleIconTextButton
            Margin="145,10,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Command="{Binding SwitchMultipleModeCommand}"
            IsChecked="{Binding MultiSelect, Mode=TwoWay}"
            Style="{DynamicResource VectorToggleIconTextButtonStyle}"
            Text="多选"
            ToolTipService.BetweenShowDelay="0"
            ToolTipService.InitialShowDelay="0">
            <VectorButtong:VectorToggleIconTextButton.ToolTip>
                <ToolTip
                    Background="#484848"
                    Content="开启多选后，同一个槽中只需满足一个成员即可匹配"
                    Foreground="White" />
            </VectorButtong:VectorToggleIconTextButton.ToolTip>
        </VectorButtong:VectorToggleIconTextButton>
        <Grid HorizontalAlignment="Right" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Input:VectorTextBox
                Grid.Row="0"
                Height="25"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Center"
                BorderBrush="Black"
                BorderThickness="1"
                Foreground="White"
                Style="{DynamicResource VectorTextBoxStyle}"
                Text="{Binding GroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                WaterMarkerBrush="Gray"
                WaterMarkerMargin="5 0 0 0"
                WaterMarkerText="组标识符" />
            <Input:VectorTextBox
                Grid.Row="1"
                Grid.Column="1"
                Height="25"
                VerticalContentAlignment="Center"
                BorderBrush="Black"
                BorderThickness="1"
                Foreground="White"
                Style="{DynamicResource VectorTextBoxStyle}"
                Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                WaterMarkerBrush="Gray"
                WaterMarkerMargin="5 0 0 0"
                WaterMarkerText="文件名" />
            <Input:VectorNumbericUpDown
                Grid.Row="2"
                Grid.Column="1"
                VerticalContentAlignment="Center"
                BorderBrush="Black"
                BorderThickness="1"
                Foreground="White"
                Style="{DynamicResource VectorNumbericUpDownStyle}"
                Text="{Binding Count, Mode=TwoWay}"
                WaterMarkerBrush="Gray"
                WaterMarkerMargin="5 0 0 0"
                WaterMarkerText="结果数量" />
        </Grid>
        <VectorButtong:VectorFlatImageButton
            Width="25"
            Height="25"
            Margin="215,5,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Command="{Binding RunCommand}"
            Image="/Resource/Common/Image/IconArrowRight.png"
            Style="{DynamicResource VectorFlatImageButtonStyle}"
            ToolTipService.BetweenShowDelay="0"
            ToolTipService.InitialShowDelay="0">
            <VectorButtong:VectorFlatImageButton.ToolTip>
                <ToolTip
                    Background="#484848"
                    Content="F5:运行"
                    Foreground="White" />
            </VectorButtong:VectorFlatImageButton.ToolTip>
        </VectorButtong:VectorFlatImageButton>
        <Image
            Width="85"
            Height="85"
            Margin="0,40,18,5"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            AllowDrop="True"
            RenderOptions.BitmapScalingMode="NearestNeighbor"
            RenderOptions.EdgeMode="Aliased"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="Loaded">
                    <behaviors:CallMethodAction MethodName="ResultItem_Loaded" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
                <behaviors:EventTrigger EventName="Drop">
                    <behaviors:CallMethodAction MethodName="GetDropData" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
        </Image>
        <Grid
            Width="232"
            Height="215"
            Margin="2,40,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{StaticResource Frame}"
            RenderOptions.BitmapScalingMode="NearestNeighbor"
            Visibility="Collapsed">
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="Loaded">
                    <behaviors:CallMethodAction MethodName="MultiMaterialGrid_Loaded" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="25" />
            </Grid.ColumnDefinitions>
            <Grid
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="Key"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <TextBlock.ToolTip>
                        <ToolTip
                            Background="#484848"
                            Content="所有该有序合成配方用到的键。"
                            Foreground="White" />
                    </TextBlock.ToolTip>
                </TextBlock>
                <TextBox
                    Grid.Column="1"
                    Margin="3,0,0,0"
                    VerticalContentAlignment="Center"
                    BorderBrush="Black"
                    FontSize="15"
                    Foreground="White"
                    Text="{Binding CurrentKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="Tag"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <TextBlock.ToolTip>
                        <ToolTip
                            Background="#484848"
                            Content="该材料的键。"
                            Foreground="White" />
                    </TextBlock.ToolTip>
                </TextBlock>
                <TextBox
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    BorderBrush="Black"
                    FontSize="15"
                    Foreground="White"
                    Text="{Binding CurrentTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="White"
                Text="搜索" />
            <TextBox
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Height="25"
                Margin="0,2"
                BorderBrush="Black"
                FontSize="20"
                Foreground="White"
                Text="{Binding SearchText, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="TextChanged">
                        <behaviors:CallMethodAction MethodName="SearchMultiItemBox_TextChanged" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </TextBox>
            <VectorButtong:VectorFlatImageButton
                Grid.Row="0"
                Grid.Column="2"
                Width="25"
                Height="25"
                Command="{Binding UpdateAndCloseSlotGridCommand}"
                Image="/Resource/Common/Image/CloseWhite.png"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButtong:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="关闭并更新多选数据"
                        Foreground="White" />
                </VectorButtong:VectorFlatImageButton.ToolTip>
            </VectorButtong:VectorFlatImageButton>
            <Container:VectorScrollViewer
                Grid.Row="2"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                BorderBrush="Transparent"
                BorderThickness="0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <ListView
                    BorderThickness="0"
                    ItemsSource="{Binding Source={StaticResource MultiModeItemViewSource}}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <behaviors:Interaction.Triggers>
                        <behaviors:EventTrigger EventName="Loaded">
                            <behaviors:CallMethodAction MethodName="MultiMaterialViewer_Loaded" TargetObject="{Binding}" />
                        </behaviors:EventTrigger>
                        <behaviors:EventTrigger EventName="PreviewMouseRightButtonUp">
                            <behaviors:CallMethodAction MethodName="DeleteAppointItem_MouseRightButtonUp" TargetObject="{Binding}" />
                        </behaviors:EventTrigger>
                        <behaviors:EventTrigger EventName="PreviewMouseLeftButtonDown">
                            <behaviors:CallMethodAction MethodName="SelectItemToSetTag_MouseLeftButtonDown" TargetObject="{Binding}" />
                        </behaviors:EventTrigger>
                    </behaviors:Interaction.Triggers>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingWrapPanel:VirtualizingWrapPanel
                                Background="#555956"
                                ScrollViewer.CanContentScroll="True"
                                VirtualizingPanel.CacheLength="200 200"
                                VirtualizingPanel.CacheLengthUnit="Pixel"
                                VirtualizingPanel.IsVirtualizing="True" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image
                                    Width="50"
                                    Height="50"
                                    Panel.ZIndex="0"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    RenderOptions.ClearTypeHint="Enabled"
                                    SnapsToDevicePixels="True"
                                    Source="{StaticResource Slot}"
                                    ToolTipService.BetweenShowDelay="0"
                                    ToolTipService.InitialShowDelay="0"
                                    UseLayoutRounding="True" />
                                <Image
                                    Width="50"
                                    Height="50"
                                    Panel.ZIndex="1"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    RenderOptions.ClearTypeHint="Enabled"
                                    SnapsToDevicePixels="True"
                                    Source="{Binding Path=ImagePath, IsAsync=True, Mode=OneWay}"
                                    ToolTipService.BetweenShowDelay="0"
                                    ToolTipService.InitialShowDelay="0"
                                    UseLayoutRounding="True">
                                    <Image.ToolTip>
                                        <ToolTip
                                            Background="#484848"
                                            Content="{Binding IsAsync=True, Path=IDAndName, Mode=OneWay}"
                                            Foreground="White" />
                                    </Image.ToolTip>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Container:VectorScrollViewer>
        </Grid>
    </Grid>
</UserControl>

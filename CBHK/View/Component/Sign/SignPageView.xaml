<UserControl
    x:Class="CBHK.View.Component.Sign.SignPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:VectorComboBox="clr-namespace:CBHK.CustomControl.VectorComboBox"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CBHK.View.Component.Sign"
    xmlns:localContext="clr-namespace:CBHK.View.Component.Sign"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="450"
    d:DesignWidth="958"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Loaded">
            <behaviors:CallMethodAction MethodName="SignPage_Loaded" TargetObject="{Binding}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel
            Grid.Row="0"
            Height="35"
            LastChildFill="False">
            <VectorButton:VectorFlatImageButton
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding RunCommand}"
                Image="/Resource/Common/Image/IconArrowRight.png"
                ImageMargin="5"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="F5:运行"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorButton:VectorFlatImageButton
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                BorderThickness="0"
                Command="{Binding SaveCommand}"
                Image="/Resource/Common/Image/Save.png"
                ImageMargin="5"
                Style="{DynamicResource VectorFlatImageButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorFlatImageButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="保存"
                        Foreground="White" />
                </VectorButton:VectorFlatImageButton.ToolTip>
            </VectorButton:VectorFlatImageButton>
            <VectorComboBox:VectorTextComboBox
                Title="版本"
                IsReadOnly="True"
                ItemsSource="{Binding VersionSource}"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                Style="{DynamicResource VectorTextComboBoxStyle}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="SelectionChanged">
                        <behaviors:CallMethodAction MethodName="Version_SelectionChanged" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </VectorComboBox:VectorTextComboBox>
            <VectorComboBox:VectorTextComboBox
                Title="类型"
                ItemsSource="{Binding TypeSource, IsAsync=True}"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedSignType, Mode=TwoWay}"
                Style="{DynamicResource VectorTextComboBoxStyle}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="SelectionChanged">
                        <behaviors:CallMethodAction MethodName="SignTypeSelectComboBox_SelectionChanged" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </VectorComboBox:VectorTextComboBox>
            <VectorButton:VectorToggleTextButton
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#D77A34"
                Foreground="Black"
                IsChecked="{Binding IsHanging, Mode=OneWayToSource}"
                IsEnabled="{Binding CanHanging, Mode=OneWay}"
                Style="{DynamicResource VectorToggleTextButtonStyle}"
                Text="悬挂" />
            <VectorButton:VectorToggleIconTextButton
                Foreground="Black"
                IsChecked="{Binding Give, Mode=OneWayToSource}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="给予"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0" />
            <VectorButton:VectorToggleIconTextButton
                Margin="5,0"
                Foreground="Black"
                IsChecked="{Binding IsWaxed, Mode=OneWayToSource}"
                IsEnabled="{Binding CanWaxed, Mode=OneWay}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="已裱"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <VectorButton:VectorToggleIconTextButton.ToolTip>
                    <ToolTip
                        Background="#484848"
                        Content="已裱的告示牌无法编辑内容"
                        Foreground="White" />
                </VectorButton:VectorToggleIconTextButton.ToolTip>
            </VectorButton:VectorToggleIconTextButton>
            <VectorButton:VectorToggleIconTextButton
                Margin="5,0"
                Foreground="Black"
                IsChecked="{Binding IsBack, Mode=OneWayToSource}"
                IsEnabled="{Binding HaveBackFace, Mode=OneWay}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="反面">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Click">
                        <behaviors:CallMethodAction MethodName="IsBackUpdate_Click" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </VectorButton:VectorToggleIconTextButton>
            <VectorButton:VectorToggleIconTextButton
                Margin="5,0"
                Foreground="Black"
                IsChecked="{Binding IsFrontGlowing, Mode=OneWayToSource}"
                IsEnabled="{Binding CanGlowing, Mode=OneWay}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="正面发光" />
            <VectorButton:VectorToggleIconTextButton
                Margin="5,0"
                Foreground="Black"
                IsChecked="{Binding IsBackGlowing, Mode=OneWayToSource}"
                IsEnabled="{Binding CanGlowing, Mode=OneWay}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="反面发光" />
            <VectorButton:VectorToggleIconTextButton
                Margin="5,0"
                Foreground="Black"
                IsChecked="{Binding ShowResult, Mode=OneWayToSource}"
                Style="{DynamicResource VectorToggleIconTextButtonStyle}"
                Text="显示结果" />
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <VectorButton:VectorTextButton
                Grid.Column="0"
                Background="#EFF2F1"
                Command="{Binding SetBoldCommand}"
                Foreground="Black"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="Bold"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <TextBlock FontWeight="Bold" Text="Bold" />
                <VectorButton:VectorTextButton.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="粗体"
                        Foreground="White" />
                </VectorButton:VectorTextButton.ToolTip>
            </VectorButton:VectorTextButton>
            <VectorButton:VectorTextButton
                Grid.Column="1"
                Background="#EFF2F1"
                BorderThickness="4,4,4,7"
                Command="{Binding SetItalicCommand}"
                Foreground="Black"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="斜体"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <TextBlock FontStyle="Italic" Text="Italic" />
                <VectorButton:VectorTextButton.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="斜体"
                        Foreground="White" />
                </VectorButton:VectorTextButton.ToolTip>
            </VectorButton:VectorTextButton>
            <VectorButton:VectorTextButton
                Grid.Column="2"
                Background="#EFF2F1"
                BorderThickness="4,4,4,7"
                Command="{Binding SetUnderlinedCommand}"
                Foreground="Black"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="下划线"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <TextBlock Text="Underlined">
                    <TextBlock.TextDecorations>
                        <TextDecoration />
                    </TextBlock.TextDecorations>
                </TextBlock>
                <VectorButton:VectorTextButton.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="下划线"
                        Foreground="White" />
                </VectorButton:VectorTextButton.ToolTip>
            </VectorButton:VectorTextButton>
            <VectorButton:VectorTextButton
                Grid.Column="3"
                Background="#EFF2F1"
                BorderThickness="4,4,4,7"
                Command="{Binding SetStrikethoughCommand}"
                Foreground="Black"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="删除线"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <TextBlock Text="strikethrough">
                    <TextBlock.TextDecorations>
                        <TextDecoration PenOffset="-5" />
                    </TextBlock.TextDecorations>
                </TextBlock>
                <VectorButton:VectorTextButton.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="删除线"
                        Foreground="White" />
                </VectorButton:VectorTextButton.ToolTip>
            </VectorButton:VectorTextButton>
            <VectorButton:VectorTextButton
                Grid.Column="4"
                Background="#EFF2F1"
                BorderThickness="4,4,4,7"
                Command="{Binding SetObfuscatedCommand}"
                Foreground="Black"
                Style="{DynamicResource VectorTextButtonStyle}"
                Text="混淆"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <TextBlock Text="obfuscated" />
                <VectorButton:VectorTextButton.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="混淆"
                        Foreground="White" />
                </VectorButton:VectorTextButton.ToolTip>
            </VectorButton:VectorTextButton>
            <VectorButton:VectorTextButton
                Grid.Column="5"
                Background="#EFF2F1"
                BorderThickness="4,4,4,7"
                Command="{Binding ResetCommand}"
                Style="{DynamicResource VectorTextButtonStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <TextBlock Text="Reset" />
                <VectorButton:VectorTextButton.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="重置"
                        Foreground="White" />
                </VectorButton:VectorTextButton.ToolTip>
            </VectorButton:VectorTextButton>
            <Input:VectorColorPicker
                Title="设置文本颜色"
                Grid.Column="6"
                Background="Black"
                Foreground="Black"
                SelectedColor="{Binding SelectionColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Style="{DynamicResource VectorColorPickerStyle}"
                ToolTipService.BetweenShowDelay="0"
                ToolTipService.InitialShowDelay="0">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="PropertyChanged">
                        <behaviors:CallMethodAction MethodName="ColorPickers_PropertyChanged" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <Input:VectorColorPicker.ToolTip>
                    <ToolTip
                        Background="#424242"
                        Content="颜色"
                        Foreground="White" />
                </Input:VectorColorPicker.ToolTip>
            </Input:VectorColorPicker>
        </Grid>
        <Image
            Grid.Row="2"
            Panel.ZIndex="0"
            Source="{Binding SignPanelSource, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            Stretch="Uniform" />
        <RichTextBox
            Grid.Row="2"
            Margin="0,10,0,0"
            HorizontalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            CaretBrush="White"
            FontSize="40"
            Foreground="Black"
            SelectionBrush="#0207FF">
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="Loaded">
                    <behaviors:CallMethodAction MethodName="SignTextEditor_Loaded" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
                <behaviors:EventTrigger EventName="PreviewKeyDown">
                    <behaviors:CallMethodAction MethodName="SignTextBox_KeyDown" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
                <behaviors:EventTrigger EventName="KeyUp">
                    <behaviors:CallMethodAction MethodName="SignTextBox_KeyUp" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
                <behaviors:EventTrigger EventName="PreviewMouseLeftButtonUp">
                    <behaviors:CallMethodAction MethodName="RichTextBox_PreviewMouseLeftButtonUp" TargetObject="{Binding}" />
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
        </RichTextBox>
    </Grid>
</UserControl>

<UserControl
    x:Class="CBHK.View.Component.Spawner.ReferenceEntity"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <DockPanel>
        <Border
            x:Name="EntityIcon"
            Width="30"
            Height="30"
            BorderBrush="Orange"
            BorderThickness="1" />
        <VectorButton:VectorTextButton
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="#EFF2F1"
            Click="SetEmpty_Click"
            Style="{DynamicResource VectorTextButtonStyle}"
            Text="设置为空" />
        <VectorButton:VectorTextButton
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="#EFF2F1"
            BorderThickness="4,3,4,7"
            Click="ImportFromClipboard_Click"
            Content="从剪切板读取"
            Style="{DynamicResource VectorTextButtonStyle}" />
        <VectorButton:VectorTextButton
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="#EFF2F1"
            BorderThickness="4,3,4,7"
            Click="ImportFromFile_Click"
            Content="从文件读取"
            Style="{DynamicResource VectorTextButtonStyle}" />
        <VectorButton:VectorTextButton
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            Background="#EFF2F1"
            BorderThickness="4,3,4,7"
            Click="Spawn_Click"
            Content="生成"
            Style="{DynamicResource VectorTextButtonStyle}" />
    </DockPanel>
</UserControl>

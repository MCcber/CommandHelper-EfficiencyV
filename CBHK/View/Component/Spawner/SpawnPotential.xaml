<UserControl
    x:Class="CBHK.View.Component.Spawner.SpawnPotential"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Container="clr-namespace:CBHK.CustomControl.Container"
    xmlns:CustomControl="clr-namespace:CBHK.CustomControl"
    xmlns:Input="clr-namespace:CBHK.CustomControl.Input"
    xmlns:VectorButton="clr-namespace:CBHK.CustomControl.VectorButton"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CBHK.View.Component.Spawner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <VectorButton:VectorFlatImageButton
            Grid.Row="0"
            Grid.Column="1"
            Width="25"
            Height="25"
            HorizontalAlignment="Right"
            Click="IconTextButtons_Click"
            Image="/Resource/Common/Image/Close.png"
            Style="{DynamicResource VectorFlatImageButtonStyle}" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="White"
            Text="weight"
            ToolTipService.BetweenShowDelay="0"
            ToolTipService.InitialShowDelay="0">
            <TextBlock.ToolTip>
                <ToolTip
                    Background="#484848"
                    Content="相对其他生成项的选中此生成项的权重。必须是正数，且至少为1。"
                    Foreground="White" />
            </TextBlock.ToolTip>
        </TextBlock>
        <Input:VectorNumbericUpDown
            x:Name="weight"
            Grid.Row="1"
            Grid.Column="1"
            Height="25"
            Style="{DynamicResource VectorNumbericUpDownStyle}" />
        <Container:VectorTextExpander
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="#FFE5B663"
            BorderThickness="0"
            Header="生成规则"
            Style="{DynamicResource VectorTextExpanderStyle}">
            <Grid Background="#2F2F2F">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="方块光照限制" />
                <VectorButton:VectorToggleTextButton
                    x:Name="BlockLightValueType"
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5,5,0,0"
                    Click="BlockLight_Click"
                    Foreground="White"
                    Style="{DynamicResource VectorToggleTextButtonStyle}"
                    Text="整数" />
                <Input:VectorNumbericUpDown
                    x:Name="BlockLightValue"
                    Grid.Row="0"
                    Grid.Column="2"
                    Grid.ColumnSpan="5"
                    MinWidth="300"
                    Style="{DynamicResource VectorNumbericUpDownStyle}"
                    Text="10"
                    Visibility="Collapsed" />
                <Grid
                    x:Name="BlockLightRange"
                    Grid.Row="0"
                    Grid.Column="3"
                    Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="下限" />
                    <Input:VectorNumbericUpDown
                        x:Name="BlockLightMinValue"
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{DynamicResource VectorNumbericUpDownStyle}" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="上限" />
                    <Input:VectorNumbericUpDown
                        x:Name="BlockLightMaxValue"
                        Grid.Row="0"
                        Grid.Column="3"
                        Style="{DynamicResource VectorNumbericUpDownStyle}"
                        Text="10" />
                </Grid>
                <VectorButton:VectorToggleTextButton
                    x:Name="UseDefaultBlockLightValue"
                    Grid.Row="0"
                    Grid.Column="7"
                    HorizontalAlignment="Right"
                    Foreground="White"
                    IsChecked="True"
                    Style="{DynamicResource VectorToggleTextButtonStyle}"
                    Text="使用默认值" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Text="天空光照限制" />
                <VectorButton:VectorToggleTextButton
                    x:Name="SkyLightValueType"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5,5,0,0"
                    Click="SkyLight_Click"
                    Foreground="White"
                    Style="{DynamicResource VectorToggleTextButtonStyle}"
                    Text="整数" />
                <Input:VectorNumbericUpDown
                    x:Name="SkyLightValue"
                    Grid.Row="1"
                    Grid.Column="2"
                    Grid.ColumnSpan="5"
                    MinWidth="300"
                    Style="{DynamicResource VectorNumbericUpDownStyle}"
                    Text="10"
                    Visibility="Collapsed" />
                <Grid
                    x:Name="SkyLightRange"
                    Grid.Row="1"
                    Grid.Column="2"
                    Grid.ColumnSpan="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="下限" />
                    <Input:VectorNumbericUpDown
                        x:Name="SkyLightMinValue"
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{DynamicResource VectorNumbericUpDownStyle}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="上限" />
                    <Input:VectorNumbericUpDown
                        x:Name="SkyLightMaxValue"
                        Grid.Row="1"
                        Grid.Column="3"
                        Style="{DynamicResource VectorNumbericUpDownStyle}"
                        Text="10" />
                </Grid>
                <VectorButton:VectorToggleTextButton
                    x:Name="UseDefaultSkyLightValue"
                    Grid.Row="1"
                    Grid.Column="7"
                    HorizontalAlignment="Right"
                    Foreground="White"
                    IsChecked="True"
                    Style="{DynamicResource VectorToggleTextButtonStyle}"
                    Text="使用默认值" />
            </Grid>
        </Container:VectorTextExpander>
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="White"
            Text="entity"
            ToolTipService.BetweenShowDelay="0"
            ToolTipService.InitialShowDelay="0">
            <TextBlock.ToolTip>
                <ToolTip
                    Background="#484848"
                    Content="要生成的实体。会在准备下一次生成时覆盖SpawnData的内容。"
                    Foreground="White" />
            </TextBlock.ToolTip>
        </TextBlock>
        <local:ReferenceEntity
            x:Name="entity"
            Grid.Row="3"
            Grid.Column="1" />
    </Grid>
</UserControl>

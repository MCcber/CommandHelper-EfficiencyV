                    VerticalScrollBarVisibility="Disabled">
                    <Viewbox>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image
                                Width="300"
                                VerticalAlignment="Top"
                                Source="/CBHK;component/Resource/CBHK/Image/More/Thanks/Title.png" />
                            <DockPanel
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                LastChildFill="False">
                                <VectorButton:VectorFlatImageButton
                                    Uid="1"
                                    Width="200"
                                    Height="136"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding GoToWebSiteCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self}}"
                                    Style="{DynamicResource VectorFlatImageButtonStyle}">
                                    <behaviors:Interaction.Triggers>
                                        <behaviors:EventTrigger EventName="Loaded">
                                            <behaviors:InvokeCommandAction Command="{Binding MemberHeadLoadedCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=VectorButton:VectorFlatImageButton}}" />
                                        </behaviors:EventTrigger>
                                        <behaviors:EventTrigger EventName="MouseEnter">
                                            <behaviors:InvokeCommandAction Command="{Binding MemberButtonMouseHoverCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=VectorButton:VectorFlatImageButton}}" />
                                        </behaviors:EventTrigger>
                                        <behaviors:EventTrigger EventName="MouseLeave">
                                            <behaviors:InvokeCommandAction Command="{Binding MemberButtonMouseLeaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=VectorButton:VectorFlatImageButton}}" />
                                        </behaviors:EventTrigger>
                                    </behaviors:Interaction.Triggers>
                                </VectorButton:VectorFlatImageButton>

                    </Viewbox>
                </Container:VectorScrollViewer>
            </Grid>
        </Container:VectorTextTabItem>
        <Container:VectorTextTabItem
            Title="加入QQ群一起交流"
            Foreground="White"
            Style="{DynamicResource VectorTextTabItemStyle}">
            <Image
                RenderOptions.BitmapScalingMode="HighQuality"
                Source="/CBHK;component/Resource/CBHK/Image/More/conversation_group.png"
                Stretch="Uniform">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="MouseLeftButtonUp">
                        <behaviors:CallMethodAction MethodName="ClickToJoinGroup" TargetObject="{Binding}" />
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
            </Image>
        </Container:VectorTextTabItem>
        <Container:VectorTextTabItem
            Title="反馈Bug"
            BorderThickness="4,4,4,0"
            Foreground="White"
            Style="{DynamicResource VectorTextTabItemStyle}">
            <StackPanel>
                <Image
                    Width="100"
                    Height="100"
                    Margin="0,10,0,0"
                    Source="/CBHK;component/Resource/CBHK/Image/More/github.png"
                    Stretch="Uniform" />
                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="50"
                    Foreground="White"
                    Text="Github FeedBack Url"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="10,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="25"
                    Style="{StaticResource UnderlineOnMouseOver}"
                    Text="https://github.com/MCcber/CommandHelper-EfficiencyV/issues">
                    <behaviors:Interaction.Triggers>
                        <behaviors:EventTrigger EventName="MouseLeftButtonUp">
                            <behaviors:CallMethodAction MethodName="FeedBackBlock_MouseLeftButtonUp" TargetObject="{Binding}" />
                        </behaviors:EventTrigger>
                    </behaviors:Interaction.Triggers>
                </TextBlock>
            </StackPanel>
        </Container:VectorTextTabItem>
        <Container:VectorTextTabItem
            Title="用户须知"
            Foreground="White"
            Style="{DynamicResource VectorTextTabItemStyle}">
            <RichTextBox
                Background="Transparent"
                BorderThickness="0"
                Foreground="White"
                IsHitTestVisible="False"
                IsReadOnly="True"
                IsReadOnlyCaretVisible="False">
                <FlowDocument>
                    <Paragraph
                        Margin="0,10,0,0"
                        FontSize="20"
                        FontWeight="Bold"
                        TextAlignment="Center">
                        <Run Text="本应用适用人群" />
                    </Paragraph>
                    <Paragraph
                        Margin="10,0,0,0"
                        FontSize="15"
                        TextAlignment="Left">
                        <Run Text="1.有基本编程能力" />
                    </Paragraph>
                    <Paragraph
                        Margin="10,0,0,0"
                        FontSize="15"
                        TextAlignment="Left">
                        <Run Text="2.对Minecraft原版技术体系有相对完整认知" />
                    </Paragraph>
                    <Paragraph
                        Margin="10,0,0,0"
                        FontSize="15"
                        TextAlignment="Left">
                        <Run Text="3.设备的系统为win10或更新" />
                    </Paragraph>
                    <Paragraph
                        Margin="10,0,0,0"
                        FontSize="15"
                        TextAlignment="Left">
                        <Run Text="4.上述1~3项需满足任意两项或全部" />
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
        </Container:VectorTextTabItem>
    </Container:VectorTabControl>
</UserControl>

                                        </behaviors:EventTrigger>
                                        <behaviors:EventTrigger EventName="MouseLeave">
                                            <behaviors:InvokeCommandAction Command="{Binding MemberButtonMouseLeaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=VectorButton:VectorFlatImageButton}}" />
                                        </behaviors:EventTrigger>
                                    </behaviors:Interaction.Triggers>
                                </VectorButton:VectorFlatImageButton>
                                <VectorButton:VectorFlatImageButton
                                    Uid="8"
                                    Width="200"
                                    Height="136"
